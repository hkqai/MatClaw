<?xml version="1.0" encoding="utf-8"?>
<robot name="broken_mesh_robot">
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="meshes/nonexistent_visual.dae"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="meshes/nonexistent_collision.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <link name="ros_link">
    <visual>
      <geometry>
        <mesh filename="package://my_robot/meshes/base.dae"/>
      </geometry>
    </visual>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="base_to_ros" type="fixed">
    <parent link="base_link"/>
    <child link="ros_link"/>
  </joint>
</robot>
